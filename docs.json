{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AxisFI",
  "colors": {
    "primary": "#06B6D4",
    "light": "#06B6D4",
    "dark": "#06B6D4"
  },
  "api": {
    "baseUrl": "http://127.0.0.1:8083/",
    "input": "openapi.json",
    "generate": true
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Home",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": "openapi.json",
        "groups": [
          {
            "group": "Wallets",
            "pages": [
              "GET /api/wallets"
            ]
          },{
            "group": "Balances",
            "pages": [
              "GET /api/balances"
            ]
          },{
            "group": "Deposit",
            "pages": [
              "POST /api/deposit/create"
            ]
          },{
            "group": "Quotes",
            "pages": [
              "POST /api/fx/quotes"
            ]
          },{
            "group": "Transfer",
            "pages": [
              "POST /api/transfer/create"
            ]
          },
          {
            "group": "Customers",
            "pages": [
              "POST /api/customers/create",
              "GET /api/customers/detail",
              "POST /api/customers/{customer_id}/update",
              "POST /api/customers/{customer_id}/delete"
            ]
          },
          {
            "group": "Recipients",
            "pages": [
              "POST /api/recipients/create",
              "GET /api/recipients/detail",
              "POST /api/recipients/{recipient_id}/update",
              "POST /api/recipients/{recipient_id}/delete"
            ]
          },
          {
            "group": "Transactions",
            "pages": [
              "GET /api/transactions",
              "GET /api/transactions/detail"
            ]
          },
          {
            "group": "Files",
            "pages": [
              "POST /api/files/upload",
              "GET /api/files/download/{file_id}"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Accounts",
            "pages": [
              "api-reference/account/add-bank-account",
              "api-reference/account/add-crypto-wallet"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://mintlify.com/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/axisfi.png",
    "dark": "/logo/axisfi.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@mintlify.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  }
}
